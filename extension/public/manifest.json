{
  "manifest_version": 3,
  "name": "PitchBox - Website Intelligence to Cold Outreach",
  "version": "0.1.2",
  "description": "Analyze any company website for tech stack, buying signals, and growth indicators. Generate personalized cold outreach in one click.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "scripting",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["detector.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
